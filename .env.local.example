# ─────────────────────────────────────────────────────────────────
# MLG Platform — Environment Variables
# Copy this file to .env.local and fill in values from Dashlane
# NEVER commit .env.local to git — it's in .gitignore
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Project ID: ezcikavnfchqaenweygw
# Dashboard: https://supabase.com/dashboard/project/ezcikavnfchqaenweygw
NEXT_PUBLIC_SUPABASE_URL=https://ezcikavnfchqaenweygw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=                    # Dashlane → "Supabase MLG Platform service_role"

# ── Trestle / MLS ─────────────────────────────────────────────────
# Provider: Cotality (formerly CoreLogic)
# Dashboard: https://api.cotality.com
TRESTLE_CLIENT_ID=trestle_LiveModernLMFeed20251001121107
TRESTLE_CLIENT_SECRET=                        # Dashlane → "Trestle Client Secret" — ROTATE THIS

# ── Cloudflare R2 ─────────────────────────────────────────────────
# Bucket: modernliving-properties
# Dashboard: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=f064a8b1da80605934997307846ea37d
R2_ACCESS_KEY_ID=                             # Dashlane → "R2 Access Key ID"
R2_SECRET_ACCESS_KEY=                         # Dashlane → "R2 Secret Access Key"
R2_BUCKET=modernliving-properties
R2_PUBLIC_BASE=https://images.mlrecloud.com

# ── Anthropic (Claude API) ────────────────────────────────────────
# Dashboard: https://console.anthropic.com
ANTHROPIC_API_KEY=                            # Dashlane → "Anthropic API Key"

# ── Follow Up Boss ────────────────────────────────────────────────
# Dashboard: https://app.followupboss.com
FUB_API_KEY=                                  # Dashlane → "Follow Up Boss API Key"

# ── Resend (transactional email) ──────────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=                               # Dashlane → "Resend API Key"

# ── Sync security ─────────────────────────────────────────────────
# Used to authenticate the /api/sync endpoint from Vercel cron
CRON_SECRET=                                  # Dashlane → "Cron Secret" — ROTATE THIS

# ── GitHub (for scripts/status.mjs and scripts/dispatch.mjs) ─────
# Fine-grained PAT "mlg-claude" — stored in Dashlane
# Scopes: contents, actions, workflows, pull-requests (read+write)
# Repos: twocityplazacondos, mlg-search, mlg-crm-api
GH_PAT=                                       # Dashlane → "GitHub mlg-claude PAT"

# ─────────────────────────────────────────────────────────────────
# Notes:
# - TRESTLE_CLIENT_SECRET and CRON_SECRET need rotating (appeared in chat history)
# - All values above should also be set as Vercel Environment Variables
#   at: https://vercel.com/modern-living-group/twocityplazacondos/settings/environment-variables
# - GH_PAT is local-only — do NOT add to Vercel
# ─────────────────────────────────────────────────────────────────
